# Copy to .env and fill values. Never commit real secrets.
NODE_ENV=development
PORT=5000

# Browser origin for CORS (no trailing slash). Must match how you open the app:
# http://localhost:5173 vs http://127.0.0.1:5173 are different origins.
# In NODE_ENV=development, localhost and 127.0.0.1 on any port are also allowed.
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb://127.0.0.1:27017/promptcraft_ai

# Use a long random string; 32+ characters required when NODE_ENV=production
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# Optional: omit or leave placeholder to use Demo Mode for /api/ai/generate (curated templates).
OPENAI_API_KEY=replace_with_openai_key
OPENAI_MODEL=gpt-4.1-mini

# Set to 1 when the API runs behind a reverse proxy (rate limiting / IP accuracy)
# TRUST_PROXY=1
